Right join --> All Department + matching employee 

SELECT e.empName , d.deptName FROM employee e RIGHT JOIN department d ON e.deptId = d.deptId;


Full OUTER JOIN :  LEFT + RIGHT join :

SELECT e.empName , d.deptName FROM employee e LEFT JOIN department d ON e.deptId = d.deptId
UNION 
SELECT e.empName , d.deptName FROM employee e RIGHT JOIN department d ON e.deptId = d.deptId;


CROSS JOIN : All Combinations / Possibility  

SELECT e.empName , d.deptName FROM employee e CROSS JOIN department d;




